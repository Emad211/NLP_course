# Data artifacts (large)
# -----------------------------
# Raw scraped data (can be huge)
data/raw_json/
data/**/*.json

# If you want to keep only certain JSONs tracked,
# remove the line above and add allowlist rules.

# -----------------------------
# Generated outputs
# -----------------------------
processed_data/
models/

# If you want to version-control SOME reports, comment the lines above
# and instead ignore only heavy subfolders like:
# processed_data/preprocess_steps/
# processed_data/final/
# processed_data/retriever/
# processed_data/sentiment/
# processed_data/sentiment_hybrid_v1/
# models/*.joblib

